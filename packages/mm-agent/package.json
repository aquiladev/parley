{
  "name": "@parley/mm-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Parley Market Maker Agent — deterministic Node daemon, no LLM",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@0gfoundation/0g-ts-sdk": "^1.2.6",
    "@parley/shared": "workspace:*",
    "ethers": "^6.13.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
