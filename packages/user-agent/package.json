{
  "name": "@parley/user-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Parley User Agent: Hermes runtime + AXL sidecar + calldata helpers",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "node --env-file=../../.env --import=tsx --watch axl-sidecar/src/index.ts",
    "sidecar": "node --env-file=../../.env --import=tsx axl-sidecar/src/index.ts",
    "clean": "rm -rf dist *.tsbuildinfo",
    "phase0:zg-compute": "node --env-file=../../.env --import=tsx scripts/zg-compute-hello.ts",
    "phase0:zg-storage": "node --env-file=../../.env --import=tsx scripts/zg-storage-roundtrip.ts",
    "phase3:register-mm": "node --env-file=../../.env --import=tsx scripts/register-mm.ts"
  },
  "dependencies": {
    "@0gfoundation/0g-ts-sdk": "^1.2.6",
    "@0glabs/0g-serving-broker": "^0.6.0",
    "@parley/shared": "workspace:*",
    "ethers": "^6.13.4",
    "openai": "^4.77.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
