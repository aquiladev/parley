{
  "name": "parley",
  "private": true,
  "version": "0.1.0",
  "description": "Parley — the agent layer for peer DeFi (Sepolia)",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "build": "pnpm -F @parley/shared build && pnpm -r --filter=!@parley/contracts --filter=!@parley/miniapp --filter=!@parley/shared build",
    "typecheck": "pnpm -F @parley/shared build && pnpm -r --filter=!@parley/contracts --filter=!@parley/shared typecheck",
    "test": "pnpm -r --filter=!@parley/contracts test",
    "contracts:build": "pnpm -F @parley/contracts build",
    "contracts:test": "pnpm -F @parley/contracts test",
    "miniapp:dev": "pnpm -F @parley/miniapp dev",
    "user-agent:dev": "pnpm -F @parley/user-agent dev",
    "mm-agent:dev": "pnpm -F @parley/mm-agent dev"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
