# =============================================================================
# Parley env template — copy to .env and fill in.
# All values are placeholders; never commit a real .env.
# =============================================================================

# ---- Chain ------------------------------------------------------------------
SEPOLIA_RPC_URL=https://sepolia.example/rpc
SETTLEMENT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ---- AXL sidecar (Gensyn) ---------------------------------------------------
# AXL node speaks HTTP on this address. Built from gensyn-ai/axl with `make build`.
AXL_HTTP_URL=http://localhost:9002
# ed25519 PEM. Generate with: openssl genpkey -algorithm ed25519 -out axl.pem
AXL_PRIVATE_KEY_PATH=./axl.pem

# ---- ENS (Sepolia) ----------------------------------------------------------
# Comma-separated list of MM Agent ENS subnames the User Agent discovers.
KNOWN_MM_ENS_NAMES=mm-1.parley.eth
# Phase 1 only: comma-separated AXL pubkeys (full 64-hex) the User Agent
# script broadcasts intents to. Replaced by ENS resolution in Phase 3.
KNOWN_MM_AXL_PUBKEYS=
# Parent domain owner key — only needed by the MM registration script.
PARLEY_ROOT_PRIVATE_KEY=

# ---- User Agent: Hermes / 0G Compute ----------------------------------------
TELEGRAM_BOT_TOKEN=
ZG_COMPUTE_ENDPOINT=https://compute.0g.example
ZG_COMPUTE_KEY=
# Fallback LLM if 0G Compute is unavailable.
ANTHROPIC_API_KEY=

# ---- 0G Storage -------------------------------------------------------------
ZG_STORAGE_RPC_URL=https://evmrpc-testnet.0g.ai
ZG_STORAGE_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai
# Pays for 0G Storage uploads (OG tokens, NOT Sepolia gas).
OG_PRIVATE_KEY=

# ---- MM Agent ---------------------------------------------------------------
# Sepolia-funded hot wallet. Distinct from the ENS subname owner wallet.
MM_EVM_PRIVATE_KEY=
MM_ENS_NAME=mm-1.parley.eth
MM_SPREAD_BPS=20
MM_INVENTORY_USDC=10000
MM_INVENTORY_WETH=5
# How long an MM offer remains valid (also the on-chain Deal deadline).
MM_OFFER_EXPIRY_MS=120000
# After both sides lock, how long the MM expects settle() to land before
# considering the deal abandoned. Informational in Phase 1.
MM_SETTLEMENT_WINDOW_MS=300000

# ---- User persona (Phase 1 only — no Mini App / WalletConnect yet) ----------
# Sepolia-funded EOA used by scripts/phase1-trade.ts to sign + submit lock
# and settle directly. REMOVE in Phase 2 — user-side signing moves to the
# Mini App, and there is no User Agent EVM key in production.
USER_EVM_PRIVATE_KEY=
# Where the User Agent's local AXL node listens (HTTP API). Distinct from
# the MM Agent's port so both can coexist on one machine.
USER_AXL_HTTP_URL=http://localhost:9002

# ---- Sepolia tokens (Phase 1: USDC/WETH only) -------------------------------
# Defaults are well-known canonical addresses; override only if you've deployed
# your own test tokens.
SEPOLIA_USDC_ADDRESS=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
SEPOLIA_WETH_ADDRESS=0xfFf9976782d46CC05630D1f6eBAb18b2324d6B14

# ---- Mini App (Next.js, public-prefixed where they ship to the client) ------
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_SETTLEMENT_CONTRACT_ADDRESS=
NEXT_PUBLIC_CHAIN_ID=11155111
# HTTPS URL the bot embeds in `web_app` buttons. Dev: cloudflared/ngrok tunnel.
# Production: stable hostname behind reverse proxy. Telegram refuses non-HTTPS.
MINIAPP_BASE_URL=
# Server-only: signs JWTs that the bot embeds in Mini App URLs (Phase 4).
MINIAPP_JWT_SIGNING_KEY=

# ---- Uniswap fallback -------------------------------------------------------
# Phase 5 fallback uses on-chain Uniswap v3 (QuoterV2 + SwapRouter02) directly,
# not the Trading API gateway — the gateway doesn't index Sepolia v3 pools.
# All routing reads go through SEPOLIA_RPC_URL above; no extra env needed.
